# ===========================================================================
# Paperclip Telegram Bot — Environment Configuration
# ===========================================================================

# ---- Core (Required) ----
TELEGRAM_BOT_TOKEN=your-bot-token-here
ALLOWED_USER_IDS=123456789,987654321

# ---- Paperclip API ----
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_COMPANY_ID=              # optional — auto-detected if only one company

# ---- Admin ----
ADMIN_USER_IDS=123456789           # comma-separated, for /stats and /broadcast

# ---- Webhook (leave WEBHOOK_URL empty to use polling) ----
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook

# ---- Logging ----
LOG_FORMAT=text                    # "text" or "json"
LOG_LEVEL=INFO

# ---- Rate Limiting ----
RATE_LIMIT_RPM=30                  # max requests per minute per user

# ---- Prometheus Metrics ----
METRICS_ENABLED=false
METRICS_PORT=9090

# ---- Daily Digest ----
DIGEST_ENABLED=false
DIGEST_HOUR=9
DIGEST_MINUTE=0

# ---- Internationalisation ----
LOCALE=en

# ---- HTTP Client ----
API_TIMEOUT=15.0
API_RETRIES=3
